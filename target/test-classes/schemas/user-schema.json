{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "User Object Schema",
  "description": "Validates the structure of a user resource from JSONPlaceholder API",
  "type": "object",
  "required": ["id", "name", "username", "email", "address", "phone", "website", "company"],
  "properties": {
    "id": {
      "type": "integer",
      "description": "The unique user identifier",
      "minimum": 1
    },
    "name": {
      "type": "string",
      "description": "The user's full name",
      "minLength": 1
    },
    "username": {
      "type": "string",
      "description": "The user's username",
      "minLength": 1
    },
    "email": {
      "type": "string",
      "description": "The user's email address",
      "format": "email"
    },
    "address": {
      "type": "object",
      "required": ["street", "suite", "city", "zipcode", "geo"],
      "properties": {
        "street": {
          "type": "string"
        },
        "suite": {
          "type": "string"
        },
        "city": {
          "type": "string"
        },
        "zipcode": {
          "type": "string"
        },
        "geo": {
          "type": "object",
          "required": ["lat", "lng"],
          "properties": {
            "lat": {
              "type": "string"
            },
            "lng": {
              "type": "string"
            }
          }
        }
      }
    },
    "phone": {
      "type": "string"
    },
    "website": {
      "type": "string"
    },
    "company": {
      "type": "object",
      "required": ["name", "catchPhrase", "bs"],
      "properties": {
        "name": {
          "type": "string"
        },
        "catchPhrase": {
          "type": "string"
        },
        "bs": {
          "type": "string"
        }
      }
    }
  },
  "additionalProperties": false
}
