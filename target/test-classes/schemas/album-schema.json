{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Album Object Schema",
  "description": "Validates the structure of an album resource from JSONPlaceholder API",
  "type": "object",
  "required": ["userId", "id", "title"],
  "properties": {
    "userId": {
      "type": "integer",
      "description": "The user ID associated with the album",
      "minimum": 1
    },
    "id": {
      "type": "integer",
      "description": "The unique album identifier",
      "minimum": 1
    },
    "title": {
      "type": "string",
      "description": "The album title",
      "minLength": 1
    }
  },
  "additionalProperties": false
}
