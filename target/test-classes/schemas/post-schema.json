{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Post Object Schema",
  "description": "Validates the structure of a post resource from JSONPlaceholder API",
  "type": "object",
  "required": ["userId", "id", "title", "body"],
  "properties": {
    "userId": {
      "type": "integer",
      "description": "The user ID associated with the post",
      "minimum": 1
    },
    "id": {
      "type": "integer",
      "description": "The unique post identifier",
      "minimum": 1
    },
    "title": {
      "type": "string",
      "description": "The post title",
      "minLength": 1
    },
    "body": {
      "type": "string",
      "description": "The post body content",
      "minLength": 1
    }
  },
  "additionalProperties": false
}
