{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Todo Object Schema",
  "description": "Validates the structure of a todo resource from JSONPlaceholder API",
  "type": "object",
  "required": ["userId", "id", "title", "completed"],
  "properties": {
    "userId": {
      "type": "integer",
      "description": "The user ID associated with the todo",
      "minimum": 1
    },
    "id": {
      "type": "integer",
      "description": "The unique todo identifier",
      "minimum": 1
    },
    "title": {
      "type": "string",
      "description": "The todo title",
      "minLength": 1
    },
    "completed": {
      "type": "boolean",
      "description": "Whether the todo is completed"
    }
  },
  "additionalProperties": false
}
